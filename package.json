{
  "name": "kalliope",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/thabz/Kalliope"
  },
  "private": true,
  "engines": {
    "node": ">=20.18.1"
  },
  "browserslist": [
    "defaults",
    "Safari >= 13.1",
    "iOS >= 13.4"
  ],
  "scripts": {
    "dev": " LOCALE=da_DK.UTF_8 node server.js",
    "build": "next build",
    "start": "NODE_ENV=production LOCALE=da_DK.UTF_8 node server.js",
    "test": "jest",
    "test-watch": "jest --watch",
    "test-ci": "jest",
    "test2": "next test",
    "report-ocr-candidates": "DISABLED_TESTS=\"repeated-adjacent-word\" node tools/report-ocr-candidates.js",
    "build-static": "node tools/build-static.js",
    "build-graph": "node tools/build-graph.js",
    "build-static-force-reload": "node tools/build-static.js --force-reload",
    "build-facsimiles": "node tools/build-facsimiles.js",
    "build-facsimiles-old": "node tools/build-facsimiles-old.js"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.10",
    "ics": "^2.4.1",
    "mkdirp": "^0.5.1",
    "next": "^16.2.9",
    "p-limit": "^2.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "jest": "^30.4.2"
  },
  "author": "Jesper Christensen",
  "license": "MIT",
  "type": "module"
}
